<!DOCTYPE html>
<html lang="ro">
<head>
    <%- include('../fragmente/head.ejs') %>
    <title>Eroare - Lama de Oțel</title>
    <style>
        #err-coloane {
            text-align: center;
            padding: 3em;
        }
        #err-imag img {
            max-width: 400px;
            width: 100%;
            margin: 0 auto;
            display: block;
            border-radius: 8px;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.5);
        }
        .err-text {
            margin-top: 2em;
        }
    </style>
</head>
<body id="top">
    <%- include('../fragmente/header.ejs') %>
    <main id="grid-pagina">
        <section style="grid-column: 1 / -1;">
            <div id="err-coloane">
                <div id="err-imag">
                    <img src="<%- locals.imagine %>" alt="Imagine eroare" />
                </div>
                <div class="err-text">
                    <h2><%- locals.titlu %></h2>
                    <p><%- locals.text %></p>
                    <br>
                    <a href="/" class="btn-inapoi"><i class="fa-solid fa-arrow-left"></i> Înapoi la Magazin</a>
                </div>
            </div>
        </section>
    </main>
    <%- include('../fragmente/footer.ejs') %>
</body>
</html>