<!DOCTYPE html>
<html lang="ro">
<head>
    <%- include('../fragmente/head.ejs') %>
</head>
<body id="top">
    <%- include('../fragmente/header.ejs') %>

    <main class="container mt-5">
        <h1 class="text-center mb-4 text-white">Galerii de Imagini</h1>
        
        <section id="galerie_statica">
            <%- include('../fragmente/galerie.ejs') %>
        </section>

        <section id="galerie_dinamica" class="mt-5 mb-5 pb-5">
            <h2 class="text-center text-white mb-4">Galerie Animată</h2>
            <div id="galerie-animata">
                <% for(let i = 0; i < locals.imaginiAnimata.length; i++) { %>
                    <img class="anim-img" src="<%- locals.imaginiAnimata[i].cale_fisier_relativ %>" alt="Imagine animata">
                <% } %>
            </div>
        </section>
    </main>

    <%- include('../fragmente/footer.ejs') %>
</body>
</html>
